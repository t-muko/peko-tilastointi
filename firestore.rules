rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Private training data: only the owner can read/write
    match /reenit/{userId}/reenit/{doc} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // In Firestore you don't actually need to create the parent document /reenit/{userId} 
    // to write subcollection documents under it — Firestore creates the path implicitly. 
    
    // Shared aggregated statistics:
    // - Everyone can read
    // - Only the owner can write their own stats
    match /tilastot/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  
    
    // Anonymous training data:
    // - Authenticated users can read
    // - No one can write
    match /reenit/anonyymi/{document} {
      allow read: if request.auth != null;
      allow write: if false;
    }

  }
}
