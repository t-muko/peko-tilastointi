rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Private training data: only the owner can read/write
    match /reenit/{userId}/reenit/{doc} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Shared aggregated statistics:
    // - Everyone can read
    // - Only the owner can write their own stats
    // match /tilastot/{userId} {
    //  allow read: if true;
    //  allow write: if request.auth != null && request.auth.uid == userId;
    // }

    // Anonymous training data:
    // - Authenticated users can read
    // - No one can write
    match /reenit/anonyymi/{document} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // match /reenit/{userId} {
    //     allow get: if request.auth != null && request.auth.uid == userId;
    //     allow list: if false;
    //     allow write: if request.auth != null && request.auth.uid == userId;
      
    // match /reenit/{doc} {
    //    allow read: if request.auth != null;
    //    allow write: if request.auth != null;
    //   }
    // }

    match /tilastot/{userId} {
        allow get: if request.auth != null;
        allow list: if request.auth != null;
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
        }
  }
}
