{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@root/*": [
                "./*"
            ],
            "@/*": [
                "src/*"
            ],
            "@components/*": [
                "src/components/*"
            ],
            "@stores/*": [
                "src/stores/*"
            ],
            "@hooks/*": [
                "src/hooks/*"
            ]
        }
    },
    "include": [
        "src"
    ]
}